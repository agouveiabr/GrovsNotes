{
  "name": "grovsnotes",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/web' --filter './apps/desktop' dev",
    "desktop:dev": "pnpm --filter @grovsnotes/desktop tauri dev",
    "desktop:build": "pnpm --filter @grovsnotes/desktop tauri build",
    "build": "pnpm --filter './apps/*' --filter '!@grovsnotes/desktop' --if-present build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "dependencies": {
    "convex": "^1.15.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
